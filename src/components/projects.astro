---
import { Image } from "astro:assets";
import placeholderImg from "../../public/moviesfordevs.png";

interface Project {
  title: string;
  image: ImageMetadata;
  link: string;
  preview: string;
  description: string;
  tech: string;
  details: string[];
}

const projects: Project[] = [
  {
    title: "OmniLocal",
    image: placeholderImg as ImageMetadata,
    link: "https://github.com/ThanDongVanHoc/GDGOC-2026",
    preview: "Need info",
    description: "Top 6 Finalist, GDGOC Hackathon Vietnam 2026",
    tech: "Python, ComfyUI, Diffusion Inpainting, OpenCV",
    details: [
      "Built a 3-stage pipeline (background transformation → object replacement → Vietnamese text rendering) for cross-cultural content adaptation",
      "Integrated Qwen-Image-Edit 2509 with 4-step Lightning LoRA via ComfyUI for fast diffusion inference on cloud GPU",
      "Rendered Vietnamese text using cv2 inpainting and Qwen Image Edit for completion and aesthetics",
    ],
  },
  {
    title: "LocalFood",
    image: placeholderImg as ImageMetadata,
    link: "https://github.com/namkiet/CS252-Web-Project-Group-XXX",
    preview: "Need info",
    description: "Multi-Agent System for Personalized Local Food and Itinerary Recommendations",
    tech: "Python, Flask, Selenium, SQLite, React, TypeScript",
    details: [
      "Built backend RESTful APIs using Flask to serve structured data",
      "Scraped restaurant data using Selenium and organized it for backend APIs",
      "Stored and managed data in SQLite database to power the AI agent's knowledge base",
      "Improved query performance by caching search history to reduce LLM response latency",
    ],
  },
];
---

<section
  id="projects"
  class="py-12 border-t border-[var(--component-border)] text-[var(--white)] scroll-reveal"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">My work</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">Projects</h3>

    <div class="flex flex-col">
      {
        projects.map((project, index) => (
          <>
            {index > 0 && (
              <div class="w-full h-px bg-gradient-to-r from-transparent via-[var(--sec)] to-transparent opacity-30 my-12"></div>
            )}
            <div class={`flex flex-col ${index % 2 === 1 ? "md:flex-row-reverse" : "md:flex-row"} items-center gap-6 md:gap-8 group`}>
            <div class="md:w-1/2 w-full relative">
              <a
                href={project.preview}
                target="_blank"
                rel="noopener noreferrer"
                class="block overflow-hidden rounded-2xl"
              >
                <Image
                  src={project.image}
                  alt={project.title}
                  class="w-full h-48 md:h-72 object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </a>
              <div class="absolute top-3 right-3 flex gap-2">
                <a
                  target="_blank"
                  href={project.link}
                  aria-label="GitHub"
                  class="size-10 md:size-12 flex justify-center items-center text-[var(--white-icon)] hover:text-[var(--white)] transition duration-300 ease-in-out border border-[var(--component-border)] rounded-xl bg-[var(--component-bg)] hover:bg-[var(--white-icon-tr)] backdrop-blur-sm"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="size-5 md:size-6"
                  >
                    <path d="M24 12L18.3431 17.6569L16.9289 16.2426L21.1716 12L16.9289 7.75736L18.3431 6.34315L24 12ZM2.82843 12L7.07107 16.2426L5.65685 17.6569L0 12L5.65685 6.34315L7.07107 7.75736L2.82843 12ZM9.78845 21H7.66009L14.2116 3H16.3399L9.78845 21Z" />
                  </svg>
                </a>
                <a
                  target="_blank"
                  href={project.preview}
                  aria-label="Preview"
                  class="size-10 md:size-12 flex justify-center items-center text-[var(--white-icon)] hover:text-[var(--white)] transition duration-300 ease-in-out border border-[var(--component-border)] rounded-xl bg-[var(--component-bg)] hover:bg-[var(--white-icon-tr)] backdrop-blur-sm"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="size-5 md:size-6"
                  >
                    <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
                  </svg>
                </a>
              </div>
            </div>
            <div class="md:w-1/2 w-full flex flex-col justify-center">
              <h4 class="text-3xl md:text-4xl font-semibold">{project.title}</h4>
              <p class="pt-3 text-base text-[var(--white-icon)] italic">
                {project.description}
              </p>
              <p class="py-2 text-sm text-[var(--sec)] font-mono">
                {project.tech}
              </p>
              <ul class="space-y-2">
                {project.details.map((detail) => (
                  <li class="text-base text-[var(--white-icon)] flex items-start gap-2">
                    <span class="text-[var(--sec)] mt-1">•</span>
                    <span>{detail}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          </>
        ))
      }
    </div>
    <a
      target="_blank"
      href="https://github.com/namkiet?tab=repositories"
      aria-label="GitHub"
      class="w-full flex items-center justify-center gap-2 mt-9 text-[var(--white-icon)] hover:text-[var(--white)] transition duration-300 ease-in-out border border-[var(--white-icon-tr)] p-3 rounded-full bg-[#1414149c] hover:bg-[var(--white-icon-tr)] hover:scale-105"
    >
      <span class="md:text-lg text-md">More projects on</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="size-6"
      >
        <path
          d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"
        ></path>
      </svg>
    </a>
  </div>
</section>
